# ============================================================
# appsec-ai-platform — Environment Configuration Template
# Copy this file to .env and fill in values as needed.
# NEVER commit .env to version control.
# ============================================================


# ── Identity ─────────────────────────────────────────────────────────────────

# Auditor display name written into all evidence files and findings.
# Used when --auditor is not passed on the command line.
AUDIT_DEFAULT_AUDITOR=


# ── Audit run defaults ────────────────────────────────────────────────────────
# These values are used as defaults when the equivalent CLI flag is not provided.

# Comma-separated list of target URLs for audit commands.
# Example: AUDIT_TARGET_URLS=https://app.example.com,https://api.example.com
# Used when --url is not passed on the command line.
AUDIT_TARGET_URLS=

# Path to the findings register Markdown file.
# Defaults to audit-runs/active/findings-register.md when not set.
# Used when --register is not passed on the command line.
AUDIT_REGISTER_PATH=

# Path to a dependency manifest file (requirements.txt, package.json, etc.).
# Used when --manifest is not passed on the command line.
AUDIT_MANIFEST_PATH=

# Path to an OpenAPI or Postman collection spec file.
# Used when --spec is not passed on the command line.
AUDIT_SPEC_PATH=

# Path to a directory or file for secrets scanning.
# Used when --scan is not passed on the command line.
AUDIT_SCAN_PATH=

# Maximum number of pages the passive crawler will visit per run.
AUDIT_MAX_CRAWL_PAGES=30


# ── Report defaults ───────────────────────────────────────────────────────────

# Target application name written into all generated reports.
# Used when --target is not passed on report commands.
AUDIT_TARGET_NAME=

# Report version label. Use "Final v1.0" for production-ready reports.
# Used when --version is not passed on report commands.
AUDIT_REPORT_VERSION=DRAFT v0.1


# ── HTTP client ───────────────────────────────────────────────────────────────

# HTTP request timeout in seconds (connect, read)
AUDIT_REQUEST_TIMEOUT=15

# User-agent string sent in all audit requests
AUDIT_USER_AGENT=appsec-audit-tool/1.0

# Maximum redirects to follow per request
AUDIT_MAX_REDIRECTS=5

# Set to false ONLY for staging environments with self-signed certs.
# NEVER set to false against production targets.
AUDIT_SSL_VERIFY=true


# ── External APIs ─────────────────────────────────────────────────────────────

# OSV.dev API base URL (no key required)
OSV_API_BASE_URL=https://api.osv.dev/v1
